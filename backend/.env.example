# Copy to .env and fill in real values. NEVER commit real secrets.
# DART (Korean OpenDART) API key - placeholder only.
DART_API_KEY=your-dart-api-key-placeholder
DART_BASE_URL=https://opendart.fss.or.kr/api
# SEC EDGAR requires a User-Agent that includes contact info (name + email).
SEC_BASE_URL=https://data.sec.gov
SEC_USER_AGENT=filing-digest/0.1.0 your-contact@example.com
DATABASE_URL=postgresql+psycopg://filing_digest:filing_digest_dev@localhost:5432/filing_digest
# [Verified] 1024 dims: KURE-v1 (nlpai-lab/KURE-v1) dense dimension.
# Reserved, not consumed yet - the schema dimension is fixed by vector(1024)
# in backend/db/init.sql; changing this value alone has no effect today.
EMBEDDING_DIM=1024
