# Copy to .env and fill in real values. NEVER commit real secrets.
# DART (Korean OpenDART) API key. Issue/manage one at https://opendart.fss.or.kr
# (인증키 신청·관리). Leave blank here; set the real value only in .env (gitignored).
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
# Solar (Upstage) OpenAI-compatible LLM. Issue a key at https://console.upstage.ai
# Leave blank here; set the real value only in .env (gitignored). The key travels
# only in the Authorization header. SOLAR_MODEL is configurable (exact name may change).
SOLAR_API_KEY=
SOLAR_BASE_URL=https://api.upstage.ai/v1
SOLAR_MODEL=solar-pro3
# SEC EDGAR requires a User-Agent that includes contact info (name + email).
SEC_BASE_URL=https://data.sec.gov
SEC_USER_AGENT=filing-digest/0.1.0 your-contact@example.com
DATABASE_URL=postgresql+psycopg://filing_digest:filing_digest_dev@localhost:5433/filing_digest
# [Verified] 1024 dims: KURE-v1 (nlpai-lab/KURE-v1) dense dimension.
# Reserved, not consumed yet - the schema dimension is fixed by vector(1024)
# in backend/db/init.sql; changing this value alone has no effect today.
EMBEDDING_DIM=1024
